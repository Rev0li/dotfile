# ═══════════════════════════════════════════════════════════
# 🚫 Fichiers et dossiers à ignorer
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# 📁 Configurations locales
# ─────────────────────────────────────────────
# Configuration locale (contient des secrets, tokens, etc.)
zsh/local.zsh

# ─────────────────────────────────────────────
# 🗃️ Backups
# ─────────────────────────────────────────────
*_backup_*/
backup_*/
*.backup

# ─────────────────────────────────────────────
# 📝 Logs et temporaires
# ─────────────────────────────────────────────
*.log
*.tmp
*.temp
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────
# 🔧 Fichiers système
# ─────────────────────────────────────────────
discord/
pulse/
.vscode/
.idea/
*.swp
*.swo
*~

# ─────────────────────────────────────────────
# 📦 Binaires téléchargés (bin/)
# On ignore les binaires mais on garde les scripts .sh
# ─────────────────────────────────────────────
bin/starship
bin/hx
bin/wezterm
bin/wezterm-gui
bin/wezterm-mux-server
bin/mdcat
bin/clangd

# Dossiers extraits (volumineux)
bin/wezterm-app/
bin/helix-runtime/

# ─────────────────────────────────────────────
# 🎨 Fichier d'état du thème (local à la machine)
# ─────────────────────────────────────────────
# Pas dans le repo — géré par theme-toggle.sh sur chaque machine
# ~/.config/theme et ~/.config/theme-env sont hors du repo de toute façon

# ─────────────────────────────────────────────
# 🗂️ Archives
# ─────────────────────────────────────────────
*.zip
*.tar.gz
*.tar.xz
*.deb
*.rpm
