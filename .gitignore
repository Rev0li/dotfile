# ═══════════════════════════════════════════════════════════
# 🚫 Fichiers et dossiers à ignorer
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# 📁 Configurations locales
# ─────────────────────────────────────────────

# Configuration locale (contient des secrets, tokens, etc.)
zsh/local.zsh

# ─────────────────────────────────────────────
# 🗃️ Backups
# ─────────────────────────────────────────────

# Dossiers de backup créés par install.sh
*_backup_*/
backup_*/
*.backup

# ─────────────────────────────────────────────
# 📝 Logs et temporaires
# ─────────────────────────────────────────────

*.log
*.tmp
*.temp
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────
# 🔧 Fichiers système
# ─────────────────────────────────────────────

.vscode/
.idea/
*.swp
*.swo
*~

# ─────────────────────────────────────────────
# 📦 Binaires téléchargés
# ─────────────────────────────────────────────

# Si tu mets des binaires dans bin/
bin/*

# ─────────────────────────────────────────────
# 🗂️ Archives
# ─────────────────────────────────────────────

*.zip
*.tar.gz
*.tar.xz
*.deb
*.rpm
